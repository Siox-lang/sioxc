module examples::counter_test;

using std::logic::{Bit, Logic};
using std::bits::uint;

entity Counter<W: integer> {
    in clk: Bit;
    in rst: Logic;
    in en: Bit;
    out count: uint[W];
}

impl Counter<W: integer> {
    let value: uint[W] = 0;

    if clk::rising {
        if rst == '1' {
            value = 0;
        } else if en {
            value = value + 1;
        }
    }

    count = value;
}

// A test entity drives the counter and checks the result.
#[test]
entity CounterTest {}

impl CounterTest {
    let clk: Bit = '0';
    let rst: Logic = '1';
    let en: Bit = '1';
    let count: uint[8];

    let dut: Counter<W = 8> = {
        .clk,
        .rst,
        .en,
        .count,
    };

    clk = not clk after 5ns;   // background clock, 10ns period

    await 10ns;
    rst = '0';

    for i in 0..9 {
        await clk::rising;
    }

    assert!(count == 10, "counter should reach 10 after 10 rising edges");
}
