module std::sim;

// Simulation helpers (spec Stage 11, modelled on VHDL's `time` units).
//
// `wait`/`tick`/`run` stimulus control is built-in simulator syntax for now
// (spec Stage 11 allows this). This module carries the time-unit constants:
// the simulator's base tick is 1 fs (the VCD timescale), so a delay of
// `10 * NS` means 10 nanoseconds.

pub const FS: integer = 1;
pub const PS: integer = 1000;
pub const NS: integer = 1000000;
pub const US: integer = 1000000000;
pub const MS: integer = 1000000000000;
