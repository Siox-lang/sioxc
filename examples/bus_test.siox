module examples::bus_test;

// Two drivers on one Logic bus, each in its own impl block (parallel
// contexts): the tristate idiom — drive or 'Z' — folds via Resolve.
entity Bus { in en_a: Bit; in a: Logic; in en_b: Bit; in b: Logic; out bus: Logic; }
impl Bus {
    bus = 'Z';
    if en_a { bus = a; }
}
impl Bus {
    bus = 'Z';
    if en_b { bus = b; }
}

#[test]
entity BusTest {}
impl BusTest {
    let en_a: Bit = '0'; let a: Logic = '1';
    let en_b: Bit = '0'; let b: Logic = '0';
    let bus: Logic;
    let d = Bus { .en_a, .a, .en_b, .b, .bus };
    await 1ns;
    assert!(bus == 'Z', "nobody driving");
    en_a = '1';
    await 1ns;
    assert!(bus == '1', "a drives");
    en_a = '0'; en_b = '1';
    await 1ns;
    assert!(bus == '0', "b drives");
    en_a = '1';
    await 1ns;
    assert!(bus == 'X', "contention");
}
