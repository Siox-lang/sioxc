module examples::counter;

using std::logic::{Bit, Logic, Clock};
using std::bits::uint;

// A parameterized up-counter with synchronous reset and enable.
#[top]
entity Counter<W: integer> {
    in clk: Clock;
    in rst: Logic;
    in en: Bit;
    out count: uint[W];
}

impl Counter<W: integer> {
    let value: uint[W] = 0;

    if clk::rising {
        if rst == '1' {
            value = 0;
        } else if en {
            value = value + 1;
        }
    }

    count = value;
}
