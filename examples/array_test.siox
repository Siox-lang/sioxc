module examples::array_test;

using std::logic::Bit;

// An array-typed signal flattens to one scalar signal per element, so each
// element gets its own trace path in the waveform.
entity Bank {
    in a: Bit[4];
    out y: Bit;
}

impl Bank {
    y = a[2];
}

#[test]
entity BankTest {}

impl BankTest {
    let a: Bit[4];
    let y: Bit;

    let dut = Bank {
        .a,
        .y,
    };

    a[2] = '1';
    assert!(y == '1', "reads a[2]");

    a[2] = '0';
    assert!(y == '0', "tracks a[2]");
}
