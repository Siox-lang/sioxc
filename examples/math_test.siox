module examples::math_test;
using std::math::{sqrt, pow, PI, floor};
entity R { in x: real; out ok: Bool; }
impl R { ok = (sqrt(x) == 3.0) and (pow(2.0, 10.0) == 1024.0) and (floor(PI) == 3.0); }
#[test] entity T {}
impl T {
  let x: real = 9.0; let ok: Bool;
  let d = R { .x, .ok };
  await 1ns;
  assert!(ok == true, "sqrt + pow + PI/floor in hardware");
}
