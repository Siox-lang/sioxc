module examples::ffi_test;

extern "C" {
    pub fn labs(v: integer) -> integer;
}

entity Abs { in x: int[8]; out y: uint[8]; }
impl Abs { y = uint[8](labs(sext(x))); }

#[test]
entity FfiTest {}
impl FfiTest {
    let x: int[8]; let y: uint[8];
    let d = Abs { .x, .y };
    x = 236;  // -20
    await 1ns;
    assert!(y == 20, "labs(-20) == 20 via libc in hardware");
}
