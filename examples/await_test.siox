module examples::await_test;
using std::logic::{Bit, Logic, Clock};
using std::bits::uint;

entity Counter<W: integer> {
    in clk: Clock;
    in rst: Logic;
    in en: Bit;
    out count: uint[W];
}
impl Counter<W: integer> {
    let value: uint[W] = 0;
    if clk::rising {
        if rst == '1' { value = 0; } else if en { value = value + 1; }
    }
    count = value;
}

#[test]
entity AwaitEdge {}
impl AwaitEdge {
    let clk: Logic = '0';
    let rst: Logic = '1';
    let en: Bit = '1';
    let count: uint[8];
    let dut = Counter<W = 8> { .clk, .rst, .en, .count };

    clock(clk, 10ns);        // background 10ns clock
    await clk::rising;       // first edge (still in reset)
    rst = '0';
    await count == 7;        // wait until the counter reaches 7
    assert!(count == 7, "reached 7 via await condition");
}
