module examples::attr_test;

// A vendor-style attribute, valid only on Pll (spec 3.5, type-targeted).
pub attr external_clock: Bool for Pll;

entity Pll { in clk: Clock; out locked: Bool; }
impl Pll { locked = true; }

entity Ram { in clk: Clock; out ok: Bool; }
impl Ram { ok = true; }

#[top]
entity Top { in clk: Clock; out l: Bool; out o: Bool; }
impl Top {
    #[external_clock = true]
    let p = Pll { .clk = clk, .locked = l };

    let r = Ram { .clk = clk, .ok = o };
}
