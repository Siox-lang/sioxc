module examples::warn_test;

entity Chk { in x: uint[8]; out y: uint[8]; }
impl Chk { y = x; }

#[test]
entity WarnTest {}
impl WarnTest {
    let x: uint[8] = 200; let y: uint[8];
    let d = Chk { .x, .y };
    await 1ns;
    // A non-fatal check: x is high but the test still passes.
    warn!(x < 100, "x is unusually high but tolerable");
    assert!(y == 200, "the fatal check still holds");
    warn!(y == 0, "second warning, also non-fatal");
}
