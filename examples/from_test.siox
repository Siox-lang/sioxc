module examples::from_test;
using std::logic::unresolved::{ULogic};

struct Pair { lo: uint[8], hi: uint[8] }

impl From<integer> for Pair {
    fn from(v: integer) -> Pair {
        return Pair { .lo = v, .hi = 42 };
    }
}

entity F { in n: uint[8]; in u: ULogic; out lo: uint[8]; out hi: uint[8]; out l: Logic; }
impl F {
    let p: Pair;
    p = Pair(integer(n));    // From<integer> for Pair (struct-valued)
    lo = p.lo;
    hi = p.hi;
    l = Logic(u);            // From<ULogic> for Logic — the world crossing
}

#[test]
entity FromTest {}
impl FromTest {
    let n: uint[8] = 7; let u: ULogic = 'Z';
    let lo: uint[8]; let hi: uint[8]; let l: Logic;
    let d = F { .n, .u, .lo, .hi, .l };
    await 1ns;
    assert!(lo == 7, "From struct field lo");
    assert!(hi == 42, "From struct field hi");
    assert!(l == 'Z', "ULogic -> Logic crossing");
    u = '1';
    await 1ns;
    assert!(l == '1', "crossing tracks");
}
