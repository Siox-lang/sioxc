module examples::inout_test;

using std::logic::Logic;

// A bidirectional pad: when enabled it drives the shared pin, otherwise it
// tristates ('Z') and lets someone else own the line. It always senses the
// resolved value on the pin. `inout` ports alias the shared net, so parallel
// pads fold through `impl Resolve for Logic` — a driven '0'/'1' wins over 'Z',
// two disagreeing drivers give 'X'.
entity Pad {
    in drive: Logic;
    in en: Logic;
    inout pin: Logic;
    out sensed: Logic;
}

impl Pad {
    pin = if en == '1' { drive } else { 'Z' };
    sensed = pin;
}

// Two pads sharing one wire — the classic tristate bus.
entity Bus {
    in da: Logic; in ea: Logic;
    in db: Logic; in eb: Logic;
    out sa: Logic; out sb: Logic;
}

impl Bus {
    let wire: Logic;
    let a = Pad { .drive = da, .en = ea, .pin = wire, .sensed = sa };
    let b = Pad { .drive = db, .en = eb, .pin = wire, .sensed = sb };
}

#[test]
entity BusTest {}

impl BusTest {
    let da: Logic; let ea: Logic;
    let db: Logic; let eb: Logic;
    let sa: Logic; let sb: Logic;
    let dut = Bus { .da, .ea, .db, .eb, .sa, .sb };

    // Pad A drives '1', pad B listens: both see '1' on the shared line.
    da = '1'; ea = '1'; db = '0'; eb = 'Z';
    await 1ns;
    assert!(sa == '1', "driver A owns the bus");
    assert!(sb == '1', "pad B senses A's value over the shared pin");

    // Pad B drives '0', pad A listens.
    ea = 'Z'; db = '0'; eb = '1';
    await 1ns;
    assert!(sa == '0', "pad A senses B's value");

    // Both drive, disagreeing: contention resolves to 'X'.
    ea = '1'; da = '1'; eb = '1'; db = '0';
    await 1ns;
    assert!(sa == 'X', "bus contention is 'X'");

    print!("inout bus ok");
}
