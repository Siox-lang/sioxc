module examples::spi_test;

using std::bits::uint;

// An SPI master (mode 0, MSB-first): on `start`, serialize `tx` onto `mosi`
// one bit per clock while sampling `miso` into a receive register. Eight bits,
// then the byte sits in `rx`. Serial wires are uint[1].
entity SpiMaster {
    in clk: Clock;
    in start: Bit;
    in tx: uint[8];
    in miso: uint[1];
    out mosi: uint[1];
    out rx: uint[8];
    out busy: Logic;
}
impl SpiMaster {
    let shift_tx: uint[8] = 0;
    let shift_rx: uint[8] = 0;
    let bits: uint[4] = 0;
    let running: Bit = '0';

    if clk::rising {
        if running {
            shift_rx = (shift_rx << 1) or uint[8](miso);
            shift_tx = shift_tx << 1;
            bits = bits + 1;
            if bits == 7 {
                running = '0';
            }
        } else {
            if start {
                shift_tx = tx;
                bits = 0;
                running = '1';
            }
        }
    }

    mosi = uint[1](shift_tx >> 7);
    rx   = shift_rx;
    busy = if running == '1' { '1' } else { '0' };
}

// Loopback harness: miso <- mosi wired in hardware (a testbench local can't
// carry a DUT output back into a DUT input, but instance wiring can).
entity SpiLoopback {
    in clk: Clock;
    in start: Bit;
    in tx: uint[8];
    out rx: uint[8];
    out busy: Logic;
}
impl SpiLoopback {
    let wire: uint[1];
    let m = SpiMaster {
        .clk, .start, .tx, .miso = wire, .mosi = wire, .rx, .busy
    };
}

#[test]
entity SpiTest {}
impl SpiTest {
    let clk: Logic = '0';
    let start: Bit = '0'; let tx: uint[8] = 0;
    let rx: uint[8]; let busy: Logic;
    let d = SpiLoopback { .clk, .start, .tx, .rx, .busy };
    clk = not clk after 5ns;

    tx = 165;            // 0xA5 = 10100101
    start = '1'; await 10ns; start = '0';
    await 80ns;
    assert!(rx == 165, "SPI loopback: received == transmitted (0xA5)");
    assert!(busy == '0', "idle after the 8-bit transfer");
}
