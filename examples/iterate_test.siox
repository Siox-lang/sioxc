module examples::iterate_test;
using std::logic::{Bit};
using std::bits::uint;
entity Sum { in xs: uint[8][4]; out total: uint[8]; }
impl Sum {
    total = xs[0] + xs[1] + xs[2] + xs[3];
}
#[test]
entity IterTest {}
impl IterTest {
    let xs: uint[8][4];
    let total: uint[8];
    let dut = Sum { .xs, .total };
    xs[0] = 1; xs[1] = 2; xs[2] = 3; xs[3] = 4;
    await 1ns;
    assert!(xs::len == 4, "array length attribute");
    // Python-style: iterate the array's elements.
    let acc: uint[8] = 0;
    for x in xs {
        acc = acc + x;
    }
    assert!(acc == 10, "sum via for-over-array");
    assert!(total == 10, "hardware agrees");
    // Loop variable binds on ranges too.
    let n: uint[8] = 0;
    for i in 0..4 {
        n = n + i;
    }
    assert!(n == 6, "0+1+2+3 via bound index");
}
