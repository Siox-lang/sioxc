module examples::range_test;

// A ranged numeric (spec 3.26) is a dynamic range assert: every settled
// value must lie in 1..10 — leaving it fails the simulation (unlike a
// wrapping uint). Initial values are real: v starts at 1, not 0.
entity Bounded { in clk: Clock; out n: integer<1..10>; }
impl Bounded {
    let v: integer<1..10> = 1;
    if clk::rising { v = v + 1; }
    n = v;
}

#[test]
entity RangeTest {}
impl RangeTest {
    let clk: Logic = '0';
    let n: integer<1..10>;
    let d = Bounded { .clk, .n };
    clk = not clk after 5ns;
    await 85ns;                       // 9 rises: 1 -> 10, the top of the range
    assert!(n == 10, "counts to the top of its range");
}
