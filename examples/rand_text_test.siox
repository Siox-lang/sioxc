module examples::rand_text_test;
using std::text::{unicode, ascii, char_of};

entity Buf { in c: Char; out n: uint[8]; }
impl Buf { n = uint[8](unicode(c)); }

#[test]
entity RandTextTest {}
impl RandTextTest {
    let c: Char = 'A'; let n: uint[8];
    let d = Buf { .c, .n };
    await 1ns;
    assert!(n == 65, "unicode('A') through hardware");
    assert!(ascii(c) == 65, "ascii table");
    assert!(unicode(char_of(955)) == 955, "round-trip a code point");

    // Deterministic randomization: same seed -> same sequence, every engine.
    seed(42);
    let a: uint[8] = randint(10, 20);
    let b: uint[8] = randint(10, 20);
    print!("randints: {} {}", a, b);
    assert!((a >= 10) and (a <= 20), "randint in bounds");
    assert!((b >= 10) and (b <= 20), "randint in bounds");
    seed(42);
    let a2: uint[8] = randint(10, 20);
    assert!(a2 == a, "reseeding reproduces");
}
