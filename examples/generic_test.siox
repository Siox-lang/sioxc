module examples::generic_test;

using std::bits::{int};

// A type-generic function with a trait bound. `fn`s inline, so each call is a
// monomorphization: the body dispatches operators on the caller's concrete
// type (int's signed `Ord` here, not the kernel unsigned compare), and the
// bound `T: Ord` is checked at the call site.
fn maxi<T: Ord>(a: T, b: T) -> T {
    if a > b { return a; }
    return b;
}

entity Pick { in x: int[8]; in y: int[8]; out m: int[8]; }
impl Pick { m = maxi(x, y); }

#[test]
entity GenericTest {}
impl GenericTest {
    let x: int[8] = 5; let y: int[8] = 251;   // y = -5
    let m: int[8];
    let d = Pick { .x, .y, .m };
    await 1ns;
    assert!(m == 5, "signed generic max: 5 > -5 via int's Ord");
}
