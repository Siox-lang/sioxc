module examples::string_test;

// Strings from the standard library: `string` is `Char[]` (unconstrained),
// a string literal supplies the length, and whole-string equality compares
// symbol by symbol.

using std::text::{string};
using std::attrs::{test};

entity Echo {
    in s: string[5];
    out o: string[5];
}

impl Echo {
    o = s;
}

#[test]
entity StringTest {}

impl StringTest {
    let s: string = "hello";
    let o: string[5];

    let dut = Echo { .s, .o };

    wait 1ns;
    assert!(o == "hello", "the echoed string matches the input");

    s = "world";
    wait 1ns;
    assert!(o == "world", "reassignment propagates through");
    assert!(o != "hello", "and no longer matches the old value");
}
