module examples::complex_test;

// Complex arithmetic from the standard library: `+` on std::math::Complex
// resolves to its operator-trait impl, inlined into the IR per field.

using std::logic::{Bit};
using std::math::{Complex};
using std::attrs::{test};

entity Adder {
    in a: Complex;
    in b: Complex;
    out z: Complex;
}

impl Adder {
    z = a + b;
}

// The `i` literal suffix comes from `impl Suffix for Complex` in std::math;
// the mixed-operand `impl "+" for integer` makes the literal form work.
entity Imag {
    out z: Complex;
}

impl Imag {
    z = 10 + 5i;
}

#[test]
entity ComplexTest {}

impl ComplexTest {
    let a: Complex = { .re = 10, .im = 0 };
    let b: Complex = { .re = 0, .im = 5 };
    let z: Complex;

    let dut = Adder { .a, .b, .z };

    await 1ns;
    assert!(z.re == 10, "10 + 5i: real part");
    assert!(z.im == 5, "10 + 5i: imaginary part");

    a = { .re = 3, .im = 4 };
    b = { .re = 1, .im = 2 };
    await 1ns;
    assert!(z.re == 4, "(3+4i) + (1+2i): real part");
    assert!(z.im == 6, "(3+4i) + (1+2i): imaginary part");

    let w: Complex;
    let imag = Imag { .z = w };

    await 1ns;
    assert!(w.re == 10, "10 + 5i: real part");
    assert!(w.im == 5, "10 + 5i: imaginary part");
}
