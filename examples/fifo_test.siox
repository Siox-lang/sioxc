module examples::fifo_test;

using std::bits::uint;

// A synchronous FIFO (circular buffer, depth 4). `push` enqueues when not
// full, `pop` dequeues when not empty; head/tail pointers wrap and `count`
// tracks occupancy. Exercises dynamic array read AND write.
entity Fifo {
    in clk: Clock;
    in push: Bit;
    in pop: Bit;
    in din: uint[8];
    out dout: uint[8];
    out full: Logic;
    out empty: Logic;
}
impl Fifo {
    let mem: uint[8][4];
    let head: uint[2] = 0;
    let tail: uint[2] = 0;
    let count: uint[3] = 0;

    if clk::rising {
        // enqueue on a valid push
        if push {
            if count < 4 {
                mem[tail] = din;
                tail = tail + 1;
                if pop {
                    if count == 0 { count = count + 1; }   // pop was a no-op
                } else {
                    count = count + 1;
                }
            }
        }
        // dequeue on a valid pop
        if pop {
            if count > 0 {
                head = head + 1;
                if push {
                    if count == 4 { count = count - 1; }   // push was a no-op
                } else {
                    count = count - 1;
                }
            }
        }
    }

    dout  = mem[head];
    full  = if count == 4 { '1' } else { '0' };
    empty = if count == 0 { '1' } else { '0' };
}

#[test]
entity FifoTest {}
impl FifoTest {
    let clk: Logic = '0';
    let push: Bit = '0'; let pop: Bit = '0'; let din: uint[8] = 0;
    let dout: uint[8]; let full: Logic; let empty: Logic;
    let d = Fifo { .clk, .push, .pop, .din, .dout, .full, .empty };
    clk = not clk after 5ns;

    await 1ns;
    assert!(empty == '1', "starts empty");

    push = '1'; din = 11; await 10ns;
    din = 22; await 10ns;
    din = 33; await 10ns;
    push = '0';
    assert!(empty == '0', "not empty after pushes");
    assert!(dout == 11, "FIFO order: front is first pushed");

    pop = '1'; await 10ns; pop = '0';
    assert!(dout == 22, "after pop, front is 22");
    pop = '1'; await 10ns; pop = '0';
    assert!(dout == 33, "then 33");
    pop = '1'; await 10ns; pop = '0';
    assert!(empty == '1', "empty after draining");
}
