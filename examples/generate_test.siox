module m;
using std::bits::uint;

// A single-stage incrementer.
entity Inc { in x: uint[8]; out y: uint[8]; }
impl Inc { y = x + 1; }

// A chain of three incrementers built by a generate loop. Each iteration
// instantiates one `Inc`, wiring stage `i`'s output into stage `i+1`'s input
// through a flattened wire array (`wires[i] -> wires[i+1]`). The loop index is
// substituted and folded at elaboration, so `wires[i+1]` resolves to a concrete
// element signal. Net effect: out = in + 3.
entity Chain { in a: uint[8]; out b: uint[8]; }
impl Chain {
    let wires: uint[8][4];
    wires[0] = a;
    for i in 0..3 {
        let inc = Inc { .x = wires[i], .y = wires[i+1] };
    }
    b = wires[3];
}

#[test] entity T {}
impl T {
    let a: uint[8] = 10;
    let b: uint[8];
    let d = Chain { .a, .b };
    await 1ns;
    print!("b={}", b);
    assert!(b == 13, "10 + 3 incrementers = 13");
}
