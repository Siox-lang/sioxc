module examples::riscv_decode_test;

using std::bits::{uint};

// RV32I instruction field decoder: split a 32-bit word into its register and
// function fields by shift-and-mask (the R/I-type field layout).
entity Decoder {
    in insn: uint[32];
    out opcode: uint[7];
    out rd: uint[5];
    out funct3: uint[3];
    out rs1: uint[5];
    out rs2: uint[5];
    out funct7: uint[7];
}
impl Decoder {
    opcode = uint[7](insn and 127);            // bits  6..0
    rd     = uint[5]((insn >> 7) and 31);      // bits 11..7
    funct3 = uint[3]((insn >> 12) and 7);      // bits 14..12
    rs1    = uint[5]((insn >> 15) and 31);     // bits 19..15
    rs2    = uint[5]((insn >> 20) and 31);     // bits 24..20
    funct7 = uint[7]((insn >> 25) and 127);    // bits 31..25
}

#[test]
entity DecodeTest {}
impl DecodeTest {
    let insn: uint[32] = 0;
    let opcode: uint[7]; let rd: uint[5]; let funct3: uint[3];
    let rs1: uint[5]; let rs2: uint[5]; let funct7: uint[7];
    let d = Decoder { .insn, .opcode, .rd, .funct3, .rs1, .rs2, .funct7 };

    // addi x5, x0, 1  =  0x00100293
    insn = 1049235;
    await 1ns;
    assert!(opcode == 19, "ADDI opcode 0x13");
    assert!(rd == 5, "rd = x5");
    assert!(funct3 == 0, "funct3 = 0");
    assert!(rs1 == 0, "rs1 = x0");

    // add x3, x1, x2  =  0x002081B3
    insn = 2130355;
    await 1ns;
    assert!(opcode == 51, "ADD opcode 0x33");
    assert!(rd == 3, "rd = x3");
    assert!(rs1 == 1, "rs1 = x1");
    assert!(rs2 == 2, "rs2 = x2");
    assert!(funct7 == 0, "funct7 = 0 (ADD)");

    // sub x3, x1, x2  =  0x402081B3  (funct7 = 0x20)
    insn = 1075872179;
    await 1ns;
    assert!(funct7 == 32, "funct7 = 0x20 (SUB)");
}
