module examples::multiclock_test;
using std::logic::{Logic, Clock};
using std::bits::uint;
entity Dual { in cf: Clock; in cs: Clock; out a: uint[8]; out b: uint[8]; }
impl Dual {
    let va: uint[8] = 0; let vb: uint[8] = 0;
    if cf::rising { va = va + 1; }
    if cs::rising { vb = vb + 1; }
    a = va; b = vb;
}
#[test]
entity M {}
impl M {
    let cf: Logic = '0'; let cs: Logic = '0';
    let a: uint[8]; let b: uint[8];
    let d = Dual { .cf, .cs, .a, .b };
    cf = not cf after 2ns;
    cs = not cs after 5ns;
    await 40ns;
    assert!(a == 10, "fast clock: 10 rises");
    assert!(b == 4, "slow clock: 4 rises");
}
