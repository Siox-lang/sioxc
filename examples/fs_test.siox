module examples::fs_test;

using std::text::{unicode};

// std::fs is Rust-shaped: functions returning values, no handles, no modes,
// nothing to close. In initializer position the COMPILER reads the file
// (include_bytes! style) — the contents bake into the design, so the native
// binary carries its ROM even if the file disappears.
entity Rom { in addr: uint[2]; out data: uint[8]; }
impl Rom {
    let mem: uint[8][4] = read("examples/rom.bin");
    data = mem[0];
}

#[test]
entity FsTest {}
impl FsTest {
    let addr: uint[2] = 0; let data: uint[8];
    let d = Rom { .addr, .data };

    // Runtime read in the testbench (runner-side).
    let s: string = read_to_string("examples/banner.txt");

    await 1ns;
    assert!(data == 17, "rom.bin[0] = 0x11, baked at compile time");
    assert!(unicode(s[0]) == 72, "banner 'H'");
    assert!(unicode(s[1]) == 105, "banner 'i'");
    assert!(exists("examples/rom.bin") == true, "exists");
    assert!(exists("examples/nope.bin") == false, "not exists");
}
