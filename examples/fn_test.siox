module examples::fn_test;
using std::math::{max, abs};
using std::numeric::{clog2};

const DEPTH: integer = 300;

// clog2 in a width position: uint[clog2(300)] = uint[9].
entity Pick { in a: uint[8]; in b: uint[8]; out hi: uint[8]; out addr: uint[clog2(DEPTH)]; }
impl Pick {
    hi = max(a, b);          // free fn inlined in hardware
    addr = 300 - 1;          // just to have a driver; width must be 9
}

#[test]
entity FnTest {}
impl FnTest {
    let a: uint[8] = 30; let b: uint[8] = 200;
    let hi: uint[8]; let addr: uint[9];
    let d = Pick { .a, .b, .hi, .addr };
    await 1ns;
    assert!(hi == 200, "max inlined in hardware");
    assert!(addr == 299, "clog2(300)=9 bits held 299");
    assert!(max(a, 42) == 42, "fn call in testbench expression");
    assert!(clog2(300) == 9, "const fn in testbench");
    assert!(abs(0 - 5) == 5, "abs");
}
