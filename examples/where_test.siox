module examples::where_test;
using std::bits::{int};

// The `where` form — identical to `fn maxi<T: Ord>`.
fn maxi<T>(a: T, b: T) -> T
where
    T: Ord,
{
    if a > b { return a; }
    return b;
}

entity Pick { in x: int[8]; in y: int[8]; out m: int[8]; }
impl Pick { m = maxi(x, y); }

#[test]
entity WhereTest {}
impl WhereTest {
    let x: int[8] = 5; let y: int[8] = 251;
    let m: int[8];
    let d = Pick { .x, .y, .m };
    await 1ns;
    assert!(m == 5, "where-bounded generic max dispatches int Ord");
}
