module examples::hierarchy_test;

// Structural hierarchy: a parent entity instantiates two sub-entities and
// wires them through an internal signal. Exercises per-instance lowering and
// cross-instance connections (each Add1 is a distinct instance).

using std::bits::uint;

entity Add1 { in a: uint[8]; out y: uint[8]; }
impl Add1 { y = a + 1; }

entity Add2 { in a: uint[8]; out y: uint[8]; }
impl Add2 {
    let mid: uint[8];
    let s1 = Add1 { .a = a, .y = mid };
    let s2 = Add1 { .a = mid, .y = y };
}

#[test]
entity HierTest {}
impl HierTest {
    let a: uint[8] = 10;
    let y: uint[8];
    let dut = Add2 { .a, .y };
    wait 1.ns;
    assert!(y == 12, "10 + 2 == 12 through two nested Add1 instances");
}
