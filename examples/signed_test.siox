module examples::signed_test;
using std::logic::{Bool};
using std::bits::{int, uint};

// Signed comparison comes from std's `impl Ord for int` — not the compiler.
entity Cmp {
    in a: int[8];
    in b: int[8];
    out lt: Bool;
    out ge: Bool;
}
impl Cmp {
    lt = a < b;
    ge = a >= b;
}

// Control: uint keeps the kernel's unsigned compare.
entity UCmp { in a: uint[8]; in b: uint[8]; out lt: Bool; }
impl UCmp { lt = a < b; }

#[test]
entity SignedTest {}
impl SignedTest {
    let a: int[8]; let b: int[8];
    let lt: Bool; let ge: Bool;
    let d = Cmp { .a, .b, .lt, .ge };
    let ua: uint[8]; let ub: uint[8]; let ult: Bool;
    let u = UCmp { .a = ua, .b = ub, .lt = ult };

    a = 255;   // -1 as int[8] two's complement
    b = 1;
    ua = 255; ub = 1;
    await 1ns;
    assert!(lt == true, "signed: -1 < 1");
    assert!(ge == false, "signed: not -1 >= 1");
    assert!(ult == false, "unsigned control: 255 > 1");

    a = 200;   // -56
    b = 156;   // -100
    await 1ns;
    assert!(lt == false, "signed: -56 > -100 (same sign)");
    assert!(ge == true, "signed: -56 >= -100");

    a = 5; b = 5;
    await 1ns;
    assert!(ge == true, "signed: 5 >= 5");
    assert!(lt == false, "signed: not 5 < 5");
}
