module examples::fsm_test;

using std::logic::{Bit, Logic, Clock};
using std::bits::uint;

enum State: uint[2] {
    Idle = 0,
    Run = 1,
    Done = 2,
}

// A 3-state FSM: Idle --(start)--> Run --> Done --> Idle.
entity Fsm {
    in clk: Clock;
    in start: Bit;
    out st: State;
}

impl Fsm {
    let state: State = State::Idle;

    if clk::rising {
        match state {
            State::Idle => {
                if start {
                    state = State::Run;
                }
            }
            State::Run => {
                state = State::Done;
            }
            _ => {
                state = State::Idle;
            }
        }
    }

    st = state;
}

#[test]
entity FsmTest {}

impl FsmTest {
    let clk: Logic = '0';
    let start: Bit = '0';
    let st: State;

    let dut = Fsm {
        .clk,
        .start,
        .st,
    };

    // Idle with start low stays Idle.
    tick(clk);
    assert!(st == State::Idle, "stays idle without start");

    // start raises the machine into Run, then it walks Run -> Done -> Idle.
    start = '1';
    tick(clk);
    assert!(st == State::Run, "idle + start -> run");

    tick(clk);
    assert!(st == State::Done, "run -> done");

    tick(clk);
    assert!(st == State::Idle, "done -> idle");
}
